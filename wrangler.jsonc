{
  // Static-assets Worker for Landi Lifts (vanilla HTML/CSS/JS, no build step).
  // Pushing to GitHub triggers Workers Builds, which runs `wrangler deploy`
  // and serves these files at https://landilifts.luke-landi.workers.dev
  "name": "landilifts",
  "compatibility_date": "2026-06-13",
  "assets": {
    "directory": "./public",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
